{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "CommonJS",
    "target": "ES2020",

    "lib": ["ES2020"],
    "types": ["node"],

    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    "strict": true,

    "sourceMap": true,
    "skipLibCheck": true
  }
}
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model banners {
  id               Int       @id @default(autoincrement())
  title            String?   @db.VarChar(255)
  subtitle         String?   @db.VarChar(255)
  image_url        String?   @db.Text
  image_width      Int?      @default(1920)
  image_height     Int?      @default(939)
  mobile_image_url String?   @db.Text
  link_url         String?   @db.Text
  col_class        String?   @db.VarChar(100) @default("col-lg-12 col-12 col-sm-6")
  position         String?   @db.VarChar(50)
  type             String?   @db.VarChar(50)
  start_date       DateTime? @db.DateTime(0)
  end_date         DateTime? @db.DateTime(0)
  is_active        Boolean?  @default(true)
  sort_order       Int?      @default(0)
  created_at       DateTime? @default(now()) @db.DateTime(0)
  updated_at       DateTime? @default(now()) @db.DateTime(0)
}


model carts {
  id               Int              @id @default(autoincrement())
  user_id          Int
  product_id       Int
  variant_id       Int
  quantity         Int              @default(1)
  created_at       DateTime         @default(now()) @db.DateTime(0)
  updated_at       DateTime         @updatedAt @db.DateTime(0)
  users            users            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "carts_ibfk_1")
  products         products         @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "carts_ibfk_2")
  product_variants product_variants @relation(fields: [variant_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "carts_ibfk_3")

  @@unique([user_id, variant_id], map: "uniq_user_variant")
  @@index([product_id], map: "product_id")
  @@index([user_id], map: "user_id")
  @@index([variant_id], map: "variant_id")
}


model coupon_usage {
  id        Int       @id @default(autoincrement())
  coupon_id Int?
  user_id   Int?
  order_id  Int?
  used_at   DateTime? @default(now()) @db.DateTime(0)
  coupons   coupons?  @relation(fields: [coupon_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "coupon_usage_ibfk_1")
  users     users?    @relation(fields: [user_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "coupon_usage_ibfk_2")
  orders    orders?   @relation(fields: [order_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "coupon_usage_ibfk_3")

  @@index([coupon_id], map: "coupon_id")
  @@index([order_id], map: "order_id")
  @@index([user_id], map: "user_id")
}

model coupons {
  id              Int            @id @default(autoincrement())
  code            String?        @unique(map: "code") @db.VarChar(50)
  type            coupons_type?
  value           Decimal?       @db.Decimal(10, 2)
  min_order_value Decimal?       @db.Decimal(10, 2)
  max_discount    Decimal?       @db.Decimal(10, 2)
  usage_limit     Int?
  used_count      Int?           @default(0)
  start_date      DateTime?      @db.DateTime(0)
  end_date        DateTime?      @db.DateTime(0)
  is_active       Boolean?       @default(true)
  coupon_usage    coupon_usage[]
}

model inventory_logs {
  id               Int                  @id @default(autoincrement())
  variant_id       Int?
  type             inventory_logs_type?
  quantity         Int?
  note             String?              @db.Text
  created_at       DateTime?            @default(now()) @db.DateTime(0)
  product_variants product_variants?    @relation(fields: [variant_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "inventory_logs_ibfk_1")

  @@index([variant_id], map: "variant_id")
}

model order_items {
  id               Int               @id @default(autoincrement())
  order_id         Int?
  product_id       Int?
  variant_id       Int?
  price            Decimal?          @db.Decimal(10, 2)
  quantity         Int?
  total            Decimal?          @db.Decimal(10, 2)
  orders           orders?           @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "order_items_ibfk_1")
  products         products?         @relation(fields: [product_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "order_items_ibfk_2")
  product_variants product_variants? @relation(fields: [variant_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "order_items_ibfk_3")

  @@index([order_id], map: "order_id")
  @@index([product_id], map: "product_id")
  @@index([variant_id], map: "variant_id")
}

model orders {
  id                        Int                    @id @default(autoincrement())
  user_id                   Int?
  order_code                String?                @unique(map: "order_code") @db.VarChar(100)
  status                    orders_status?
  payment_status            orders_payment_status?
  subtotal                  Decimal?               @db.Decimal(10, 2)
  shipping_fee              Decimal?               @db.Decimal(10, 2)
  discount_amount           Decimal?               @db.Decimal(10, 2)
  total_amount              Decimal?               @db.Decimal(10, 2)
  coupon_id                 Int?
  shipping_address_snapshot String?                @db.Text
  created_at                DateTime?              @default(now()) @db.DateTime(0)
  updated_at                DateTime?              @default(now()) @db.DateTime(0)
  coupon_usage              coupon_usage[]
  order_items               order_items[]
  users                     users?                 @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "orders_ibfk_1")
  payments                  payments[]
  shipments                 shipments[]

  @@index([user_id], map: "user_id")
}

model payments {
  id               Int              @id @default(autoincrement())
  order_id         Int?
  method           payments_method?
  amount           Decimal?         @db.Decimal(10, 2)
  status           payments_status?
  transaction_code String?          @db.VarChar(255)
  paid_at          DateTime?        @db.DateTime(0)
  created_at       DateTime?        @default(now()) @db.DateTime(0)
  orders           orders?          @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "payments_ibfk_1")

  @@index([order_id], map: "order_id")
}


model brands {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(255)
  slug String @unique @db.VarChar(255)

  logo_url    String? @db.Text
  banner_url  String? @db.Text
  description String? @db.Text

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  product_brands product_brands[]
}

model colors {
  id Int @id @default(autoincrement())

  name      String  @db.VarChar(50)
  label     String? @db.VarChar(50)
  css_class String? @db.VarChar(50)
  hex       String? @db.VarChar(20)

  product_variants product_variants[]
}

model sizes {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  product_variants product_variants[]
}

model products {
  id Int @id @default(autoincrement())

  title String @db.VarChar(255)
  slug  String @unique @db.VarChar(255)

  description String? @db.Text

  base_price Decimal  @db.Decimal(10, 2)
  old_price  Decimal? @db.Decimal(10, 2)

  sale_label    String? @db.VarChar(50)
  is_today_pick Boolean @default(false)
  is_trending Boolean @default(false)

  status products_status @default(active)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  product_images       product_images[]
  product_brands       product_brands[]
  product_category_map product_category_map[]
  product_variants     product_variants[]

  carts        carts[]
  order_items  order_items[]
  user_reviews user_reviews[]
  wishlists    wishlists[]

  instagram_gallery_products instagram_gallery_products[]
}

model product_images {
  id Int @id @default(autoincrement())

  product_id Int

  url String @db.Text

  is_main    Boolean @default(false)
  sort_order Int     @default(0)

  created_at DateTime @default(now())

  products products @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
}

model product_variants {
  id Int @id @default(autoincrement())

  product_id Int

  size_id  Int?
  color_id Int?

  sku String @unique @db.VarChar(100)

  price Decimal @db.Decimal(10, 2)

  stock          Int @default(0)
  reserved_stock Int @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  products products @relation(fields: [product_id], references: [id], onDelete: Cascade)

  sizes  sizes?  @relation(fields: [size_id],  references: [id])
  colors colors? @relation(fields: [color_id], references: [id])

  product_variant_images product_variant_images[]

  carts          carts[]
  inventory_logs inventory_logs[]
  order_items    order_items[]

  @@unique([product_id, size_id, color_id])
  @@index([product_id])
  @@index([size_id])
  @@index([color_id])
}

model product_variant_images {
  id Int @id @default(autoincrement())

  product_variant_id Int

  url String @db.Text

  is_main    Boolean @default(false)
  sort_order Int     @default(0)

  product_variants product_variants @relation(fields: [product_variant_id], references: [id], onDelete: Cascade)

  @@index([product_variant_id])
}

model product_brands {
  id Int @id @default(autoincrement())

  product_id Int
  brand_id   Int

  products products @relation(fields: [product_id], references: [id], onDelete: Cascade)
  brands   brands   @relation(fields: [brand_id],   references: [id], onDelete: Cascade)

  @@unique([product_id, brand_id])
  @@index([product_id])
  @@index([brand_id])
}

model product_categories {
  id Int @id @default(autoincrement())

  name String

  slug String @unique

  description String? @db.Text
  image_url   String? @db.Text

  parent_id Int?

  sort_order Int     @default(0)
  is_active  Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  parent   product_categories?  @relation("CategoryTree", fields: [parent_id], references: [id])
  children product_categories[] @relation("CategoryTree")

  product_category_map product_category_map[]

  @@index([parent_id])
}

model product_category_map {
  id Int @id @default(autoincrement())

  product_id  Int
  category_id Int

  products           products           @relation(fields: [product_id],  references: [id], onDelete: Cascade)
  product_categories product_categories @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@unique([product_id, category_id])
  @@index([product_id])
  @@index([category_id])
}

model review_media {
  id            Int                @id @default(autoincrement())
  review_id     Int?
  type          review_media_type?
  url           String?            @db.Text
  thumbnail_url String?            @db.Text
  created_at    DateTime?          @default(now()) @db.DateTime(0)
  user_reviews  user_reviews?      @relation(fields: [review_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "review_media_ibfk_1")

  @@index([review_id], map: "review_id")
}

model review_replies {
  id           Int           @id @default(autoincrement())
  review_id    Int?
  user_id      Int?
  reply        String?       @db.Text
  created_at   DateTime?     @default(now()) @db.DateTime(0)
  user_reviews user_reviews? @relation(fields: [review_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "review_replies_ibfk_1")
  users        users?        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "review_replies_ibfk_2")

  @@index([review_id], map: "review_id")
  @@index([user_id], map: "user_id")
}

model review_votes {
  id           Int           @id @default(autoincrement())
  review_id    Int?
  user_id      Int?
  is_helpful   Boolean?
  user_reviews user_reviews? @relation(fields: [review_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "review_votes_ibfk_1")
  users        users?        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "review_votes_ibfk_2")

  @@index([review_id], map: "review_id")
  @@index([user_id], map: "user_id")
}

model shipments {
  id            Int               @id @default(autoincrement())
  order_id      Int?
  carrier       String?           @db.VarChar(100)
  tracking_code String?           @db.VarChar(100)
  status        shipments_status?
  shipped_at    DateTime?         @db.DateTime(0)
  delivered_at  DateTime?         @db.DateTime(0)
  created_at    DateTime?         @default(now()) @db.DateTime(0)
  orders        orders?           @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "shipments_ibfk_1")

  @@index([order_id], map: "order_id")
}


model user_addresses {
  id             Int       @id @default(autoincrement())
  user_id        Int?
  receiver_name  String?   @db.VarChar(255)
  receiver_phone String?   @db.VarChar(20)
  province       String?   @db.VarChar(100)
  district       String?   @db.VarChar(100)
  ward           String?   @db.VarChar(100)
  street_address String?   @db.Text
  is_default     Boolean?  @default(false)
  created_at     DateTime? @default(now()) @db.DateTime(0)
  users          users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "user_addresses_ibfk_1")

  @@index([user_id], map: "user_id")
}

model user_reviews {
  id                   Int              @id @default(autoincrement())
  user_id              Int?
  product_id           Int?
  order_id             Int?
  variant_id           Int?
  rating               Int?
  title                String?          @db.VarChar(255)
  comment              String?          @db.Text
  is_verified_purchase Boolean?         @default(false)
  created_at           DateTime?        @default(now()) @db.DateTime(0)
  updated_at           DateTime?        @default(now()) @db.DateTime(0)
  review_media         review_media[]
  review_replies       review_replies[]
  review_votes         review_votes[]
  users                users?           @relation(fields: [user_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "user_reviews_ibfk_1")
  products             products?        @relation(fields: [product_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "user_reviews_ibfk_2")

  @@index([product_id], map: "product_id")
  @@index([user_id], map: "user_id")
}

model user_sessions {
  id            Int       @id @default(autoincrement())
  user_id       Int?
  refresh_token String?   @db.Text
  device_info   String?   @db.Text
  ip_address    String?   @db.VarChar(50)
  user_agent    String?   @db.Text
  expires_at    DateTime? @db.DateTime(0)
  revoked       Boolean?  @default(false)
  created_at    DateTime? @default(now()) @db.DateTime(0)
  users         users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "user_sessions_ibfk_1")

  @@index([user_id], map: "user_id")
}

model users {
  id             Int              @id @default(autoincrement())
  email          String           @unique(map: "email") @db.VarChar(255)
  phone          String?          @unique(map: "phone") @db.VarChar(20)
  password_hash  String           @db.VarChar(255)
  full_name      String?          @db.VarChar(255)
  avatar_url     String?          @db.Text
  gender         String?          @db.VarChar(10)
  date_of_birth  DateTime?        @db.Date
  role           String?          @default("customer") @db.VarChar(20)
  is_active      Boolean?         @default(true)
  is_verified    Boolean?         @default(false)
  last_login     DateTime?        @db.DateTime(0)
  created_at     DateTime?        @default(now()) @db.DateTime(0)
  updated_at     DateTime?        @default(now()) @db.DateTime(0)
  carts          carts[]
  coupon_usage   coupon_usage[]
  orders         orders[]
  review_replies review_replies[]
  review_votes   review_votes[]
  user_addresses user_addresses[]
  user_reviews   user_reviews[]
  user_sessions  user_sessions[]
  wishlists      wishlists[]
}

model email_otps {
  id         Int             @id @default(autoincrement())
  email      String          @db.VarChar(255)
  otp_hash   String          @db.VarChar(255)
  type       email_otps_type
  expires_at DateTime        @db.DateTime(0)
  consumed   Boolean         @default(false)
  attempts   Int             @default(0)
  created_at DateTime        @default(now()) @db.DateTime(0)

  @@index([email, type])
}

model wishlists {
  id               Int               @id @default(autoincrement())
  user_id          Int
  product_id       Int
  created_at       DateTime?         @default(now()) @db.DateTime(0)
  users            users?            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "wishlists_ibfk_1")
  products         products?         @relation(fields: [product_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "wishlists_ibfk_2")
  @@unique([user_id, product_id])
  @@index([product_id], map: "product_id")
  @@index([user_id], map: "user_id")
}

model instagram_gallery {
  id Int @id @default(autoincrement())

  image_url String @db.Text

  caption String? @db.Text

  instagram_url String? @db.Text

  username String? @db.VarChar(100)

  likes_count Int @default(0)

  sort_order Int @default(0)

  is_active Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  instagram_gallery_products instagram_gallery_products[]
}

model instagram_gallery_products {
  id Int @id @default(autoincrement())

  gallery_id Int
  product_id Int

  instagram_gallery instagram_gallery @relation(fields: [gallery_id], references: [id], onDelete: Cascade)
  products          products          @relation(fields: [product_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now())

  @@unique([gallery_id, product_id])

  @@index([gallery_id])
  @@index([product_id])
}

model shop_settings {
  id Int @id @default(autoincrement())

  // Basic
  shop_name String @db.VarChar(255)
  logo_url  String? @db.Text
  favicon_url String? @db.Text

  // Contact
  address String? @db.Text
  phone String? @db.VarChar(50)
  email String? @db.VarChar(255)

  // Google Map
  google_map_url String? @db.Text
  google_map_embed String? @db.Text

  // Social
  facebook_url String? @db.Text
  instagram_url String? @db.Text
  linkedin_url String? @db.Text
  twitter_url String? @db.Text
  youtube_url String? @db.Text
  tiktok_url String? @db.Text

  // SEO
  meta_title String? @db.VarChar(255)
  meta_description String? @db.Text
  meta_keywords String? @db.Text

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model pages {
  id Int @id @default(autoincrement())

  title String @db.VarChar(255)

  slug String @unique @db.VarChar(255)

  page_group page_group?

  meta_title String? @db.VarChar(255)
  meta_description String? @db.Text

  is_active Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  page_sections page_sections[]

  @@index([slug])
  @@index([page_group])
}

model page_sections {
  id Int @id @default(autoincrement())

  page_id Int

  title String? @db.VarChar(255)

  subtitle String? @db.Text

  content String? @db.LongText

  image_url String? @db.Text

  section_type page_section_type

  sort_order Int @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  pages pages @relation(fields: [page_id],references: [id],onDelete: Cascade)

  @@index([page_id])
  @@index([section_type])
  @@index([sort_order])
}

enum page_group {
  about_us
  resource
}

enum page_section_type {
  hero
  content
  feature
  gallery
  faq
}


enum email_otps_type {
  register
  reset_password
}

enum coupons_type {
  percent
  fixed
}

enum inventory_logs_type {
  import
  sale
  refund
  adjust
}

enum payments_method {
  cod
  momo
  vnpay
  stripe
}

enum review_media_type {
  image
  video
}

enum orders_status {
  pending
  confirmed
  shipping
  completed
  cancelled
}

enum orders_payment_status {
  unpaid
  paid
  failed
  refunded
}

enum payments_status {
  pending
  success
  failed
  refunded
}

enum shipments_status {
  preparing
  shipped
  delivered
  returned
}

enum products_status {
  active
  inactive
  out_of_stock
}
